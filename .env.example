# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/siwes_db
DATABASE_URL_DEV=sqlite:///./siwes_dev.db
# Priority: NEON_URL (if set) > SUPABASE_URL > DATABASE_URL
NEON_URL=postgresql://user:password@ep-your-project.us-east-2.aws.neon.tech/neondb?sslmode=require
SUPABASE_URL=postgresql://postgres.your-project:password@aws-0-region.pooler.supabase.com:6543/postgres

# Security
SECRET_KEY=your-secret-key-change-in-production-use-secrets-token-hex-32
SESSION_LIFETIME_HOURS=24
OFFLINE_LOGIN_GRACE_DAYS=7
OFFLINE_SYNC_GRACE_DAYS=3

# Geofencing Configuration
GEOFENCE_DEFAULT_RADIUS_METERS=500
GEOFENCE_TOLERANCE_METERS=50

# LiveKit Configuration
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret
CALL_RING_TIMEOUT_SECONDS=75

# Application Settings
DEBUG=False
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development
AUTO_INIT_DB=False
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=5
