# FastAPI Cloud production environment variables
# Copy these into FastAPI Cloud manually. Do not import the full local .env.

ENVIRONMENT=production
DEBUG=False
AUTO_INIT_DB=False

SUPABASE_URL=postgresql://postgres.your-project:password@aws-0-region.pooler.supabase.com:6543/postgres
# Use Supabase transaction pooler port 6543, not session pooler port 5432.
SECRET_KEY=replace-with-a-long-random-secret

LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=replace-with-livekit-api-key
LIVEKIT_API_SECRET=replace-with-livekit-api-secret

SESSION_LIFETIME_HOURS=24
OFFLINE_LOGIN_GRACE_DAYS=7
OFFLINE_SYNC_GRACE_DAYS=3
CALL_RING_TIMEOUT_SECONDS=75

GEOFENCE_DEFAULT_RADIUS_METERS=500
GEOFENCE_TOLERANCE_METERS=50
# Set to False to use connection pooling (recommended for performance)
# Set to True only if us ing Supabase session pooler or connection issues persist
DB_DISABLE_POOLING=False
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=5

